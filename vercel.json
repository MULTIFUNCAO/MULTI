{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.multifuncao.com.br" }],
      "destination": "https://multifuncao.com.br/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}

{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.multifuncao.com.br" }],
      "destination": "https://multifuncao.com.br/:path*",
      "permanent": true
    }
  ]
}
